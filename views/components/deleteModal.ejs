<div x-cloak x-data="{ 
    showDelete: false, 
    firearmId: null,
    modelName: '' 
  }" @open-delete-modal.window="showDelete = true; firearmId = $event.detail.id; modelName = $event.detail.name" x-show="showDelete" class="fixed inset-0 z-60 flex items-center justify-center bg-black/60 backdrop-blur-sm">
  <div @click.away="showDelete = false" class="bg-slate-800 border-2 border-slate-700 p-8 rounded-2xl shadow-2xl max-w-sm w-full mx-4 transform transition-all">
    <div class="text-center flex flex-col gap-3.5">
      <div class="flex justify-center items-center gap-2.5">
        <div class="bg-red-500/10 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">Confirm Delete</h3>
      </div>

      <p class="text-slate-400 text-sm mb-6">
        Are you sure you want to delete <span class="text-red-400 font-semibold" x-text="modelName"></span>? This action is permanent.
      </p>

      <div class="flex gap-3">
        <button @click="showDelete = false" class="flex-1 px-4 py-2 bg-slate-700 hover:bg-slate-600 text-white rounded-lg font-medium transition">
          Cancel
        </button>
        <button @click="deleteFirearm(firearmId)" class=" flex-1 px-4 py-2 bg-red-600 hover:bg-red-500 text-white rounded-lg font-medium transition">
          Yes, Delete
        </button>
      </div>
    </div>
  </div>
</div>