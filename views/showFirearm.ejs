<%- include('./components/deleteModal') %>

<div class="bg-slate-950 text-slate-200 min-h-screen font-sans">

  <!-- Nav bar -->
  <nav class="border-b border-slate-800 bg-slate-900/50 backdrop-blur-md sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
      <a href="/" class="text-slate-400 hover:text-white transition-colors flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path d="M15 19l-7-7 7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        Back to Armory
      </a>
      <div class="flex gap-3">
        <a href="/firearm/edit/<%= firearm.firearmid %>" class="flex items-center bg-slate-800 hover:bg-slate-700 px-4 py-2 rounded-lg text-sm font-medium transition">Edit Details</a>
        <button type="button" @click="$dispatch('open-delete-modal', { id: '<%= firearm.firearmid %>', name: '<%= firearm.modelname %>' })" class="bg-red-600 hover:bg-red-700 text-white px-6 py-2 rounded-xl font-bold transition cursor-pointer">
          Delete Firearm
        </button>
      </div>
    </div>
  </nav>

  <main class="max-w-7xl mx-auto px-6 py-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

      <!-- Image -->
      <div class="lg:col-span-8 space-y-2">
        <div class=" flex items-center justify-center bg-linear-to-b from-slate-900 to-slate-950 rounded-3xl p-4 md:p-8 border border-slate-800 shadow-2xl ">
          <img src="<%= firearm.imagepath %>" alt="Firearm Image" class="w-fit max-h-fit rounded object-contain drop-shadow-[0_20px_50px_rgba(0,0,0,0.8)]" onerror="this.src='https://clipart-library.com/images/XyckbAKTE.png'">
        </div>

        <!-- Attachment Section | will implement later -->
