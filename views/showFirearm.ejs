          <div class="flex justify-between items-center mb-6">
            <h2 class="text-2xl font-bold tracking-tight">Mounted Attachments</h2>
            <button class="text-blue-400 hover:text-blue-300 text-sm font-semibold">+ Add Attachment</button>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl flex items-center gap-4">
              <div class="w-16 h-16 bg-black rounded-lg flex-shrink-0 flex items-center justify-center p-2">
                <img src="/path-to-optic-icon.png" class="opacity-50">
              </div>
              <div>
                <h3 class="font-bold text-slate-100">Trijicon RMR</h3>
                <p class="text-xs text-slate-500 uppercase">Optic • Red Dot</p>
              </div>
            </div>

            <div class="bg-slate-900/50 border border-dashed border-slate-800 p-4 rounded-xl flex items-center justify-center text-slate-600">
