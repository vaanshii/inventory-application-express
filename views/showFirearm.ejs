            </div>
          </div>
        </section> -->
      </div>

      <div class="lg:col-span-4 space-y-6">
        <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-xl">
          <div class="mb-6">
            <span class="text-blue-500 text-xs font-black uppercase tracking-widest"><%= firearm.category_name %></span>
            <h1 class="text-3xl font-black text-white mt-1 uppercase"><%= firearm.modelname %></h1>
          </div>

          <div class="flex flex-col gap-4">
            <div class="space-y-4">
              <div class="flex justify-between py-3 border-b border-slate-800">
                <span class="text-slate-500 text-sm">Manufacturer</span>
                <span class="text-slate-200 font-medium res-text-body-text text-end"><%= firearm.manufacturer_name %> (<%= firearm.manufacturer_country %>)</span>
              </div>
              <div class="flex justify-between py-3 border-b border-slate-800">
                <span class="text-slate-500 text-sm">Serial Number</span>
                <span class="text-slate-200 font-mono res-text-body-text"><%= firearm.serialnumber %></span>
              </div>
              <div class="flex justify-between py-3 border-b border-slate-800">
                <span class="text-slate-500 text-sm">Caliber</span>
                <span class="text-yellow-500 font-bold res-text-body-text"><%= firearm.caliber %></span>
              </div>
              <div class="flex justify-between py-3 border-b border-slate-800">
                <span class="text-slate-500 text-sm">Ammo Config</span>
                <span class="text-slate-200 res-text-body-text"><%= firearm.ammo_category %></span>
              </div>
            </div>

            <div class="mt-8 bg-slate-950/50 rounded-xl p-4 border border-slate-800/50">
              <div class="flex justify-between items-center">
                <span class="text-xs text-slate-500 uppercase font-bold tracking-tighter">Acquisition Value</span>
                <span class="text-green-500 font-bold">$<%= firearm.purchaseprice %></span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-xs text-slate-500 uppercase font-bold tracking-tighter">Purchase Date</span>
                <span class="text-slate-400 text-xs"><%= new Date(firearm.purchasedate).toLocaleDateString() %></span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>
</div>